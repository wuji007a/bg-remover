# 背景移除API配置
BG_REMOVER_PROVIDER=remove.bg  # 选项: remove.bg, clipdrop
BG_REMOVER_API_KEY=your-api-key-here

# ClipDrop API配置（切换到clipdrop时使用）
# 注册地址: https://clipdrop.co/apis
# 成本: $0.0025/次（≈¥0.02/次）
# CLIPDROP_API_KEY=your-clipdrop-api-key-here

# Google OAuth 配置
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/callback
